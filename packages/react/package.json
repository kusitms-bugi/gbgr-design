{
	"name": "@gbgr/react",
	"version": "0.2.0",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./accordion.css": "./src/accordion/accordion.css",
		"./button.css": "./src/button/button.css",
		"./checkbox.css": "./src/checkbox/checkbox.css",
		"./filter-chip.css": "./src/filter-chip/filter-chip.css",
		"./menu.css": "./src/menu/menu.css",
		"./mode-toggle.css": "./src/mode-toggle/mode-toggle.css",
		"./text-field.css": "./src/text-field/text-field.css",
		"./styles.css": "./src/styles.css",
		"./segmented-control.css": "./src/segmented-control/segmented-control.css",
		"./toggle-switch.css": "./src/toggle-switch/toggle-switch.css",
		"./radio.css": "./src/radio/radio.css"
	},
	"dependencies": {
		"@gbgr/icons": "workspace:*",
		"@radix-ui/react-switch": "^1.2.6",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0"
	},
	"scripts": {
		"build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"devDependencies": {
		"@types/react": "latest",
		"@types/react-dom": "latest",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"typescript": "latest"
	}
}
