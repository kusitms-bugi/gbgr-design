{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!!**/dist",
			"!!**/.next",
			"!!**/storybook-static",
			"!!**/.turbo",
			"!!.claude",
			"!!packages/tokens/src/tokens-studio.json"
		]
	},
	"formatter": {
		"enabled": true,
		"includes": ["**"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noImportantStyles": {
					"level": "warn"
				}
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"overrides": [
		{
			"includes": ["apps/docs/.docusaurus/**"],
			"linter": {
				"enabled": false
			},
			"formatter": {
				"enabled": false
			},
			"assist": {
				"actions": {
					"source": {
						"organizeImports": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/docs/src/generated/**"],
			"linter": {
				"enabled": false
			},
			"formatter": {
				"enabled": false
			},
			"assist": {
				"actions": {
					"source": {
						"organizeImports": "off"
					}
				}
			}
		},
		{
			"includes": [
				"packages/icons/src/components/**",
				"packages/icons/src/types.ts"
			],
			"linter": {
				"rules": {
					"a11y": {
						"noSvgWithoutTitle": {
							"level": "off"
						}
					}
				}
			},
			"formatter": {
				"enabled": false
			},
			"assist": {
				"actions": {
					"source": {
						"organizeImports": "off"
					}
				}
			}
		}
	]
}
